    "e8917c11-cfb2-4b9e-b896-1bec89cb07be": {
      "id": "e8917c11-cfb2-4b9e-b896-1bec89cb07be",
      "transcriptId": "84e0dedc-37aa-4ddf-9d95-fbc88c1f1ba9",
      "speakerName": "李记者",
      "speakerIndex": 1,
      "startTime": 26,
      "endTime": 29.5,
      "content": "理解。那回到公开信息层面，贵公司在市场份额方面有什么优势？",
      "wordCount": 1,
      "isSensitive": true,
      "sensitiveCategories": [
        "financial"
      ],
      "sortOrder": 7,
      "createdAt": 1782086564107,
      "updatedAt": 1782086564107
    },
    "4f3d9dff-cf67-426c-ba3e-592b513904d0": {
      "id": "4f3d9dff-cf67-426c-ba3e-592b513904d0",
      "transcriptId": "84e0dedc-37aa-4ddf-9d95-fbc88c1f1ba9",
      "speakerName": "张总",
      "speakerIndex": 0,
      "startTime": 29,
      "endTime": 32.5,
      "content": "我们在行业内的市场份额大约占25%左右，处于领先地位。这主要得益于我们的技术优势和服务质量。",
      "wordCount": 1,
      "isSensitive": true,
      "sensitiveCategories": [
        "financial"
      ],
      "sortOrder": 8,
      "createdAt": 1782086564107,
      "updatedAt": 1782086564107
    },
